# ── ListFlow Server Environment Variables ─────────────────────────────────────
# Copy to .env for local dev. On Railway: set these as service variables.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3016
# Production: set to your Railway client service URL
ALLOWED_ORIGIN=http://localhost:5186
# NEVER set to true in production
NO_AUTH=false

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ── AI / Speech services ──────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your-deepgram-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GEMINI_API_KEY=your-gemini-api-key

# ── FileFlow integration (optional) ──────────────────────────────────────────
FILEFLOW_URL=
FILEFLOW_EMAIL=
FILEFLOW_PASSWORD=
